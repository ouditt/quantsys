# Copy this file to .env and fill in credentials for the venue you use.
# .env is git-ignored — NEVER commit real keys.

# Venue: paper (built-in simulator) | alpaca | ibkr
QTSYS_BROKER=paper

# ---- Alpaca ----------------------------------------------------------------
# ALPACA_PAPER=1 -> paper account (use your PAPER key pair)
# ALPACA_PAPER=0 -> LIVE account, REAL MONEY (use your live key pair)
ALPACA_API_KEY=your-key-id-here
ALPACA_SECRET_KEY=your-secret-here
ALPACA_PAPER=1

# ---- IBKR (requires TWS or IB Gateway running with API enabled) -------------
# Paper ports: TWS 7497, IB Gateway 4002
# LIVE ports (REAL MONEY): TWS 7496, IB Gateway 4001
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
