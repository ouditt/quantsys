# secrets — never commit broker keys
.env
*.key

# python
__pycache__/
*.pyc
.venv/
venv/

# runtime state (agent logs, posture kv) — regenerated on boot
*.db
*.db-wal
*.db-shm

# universe scan runtime data (bars cache, ML selector store/model)
qtsys/universe_cache/
*.pkl
# scan output churns on every run — written at runtime, not source-controlled
qtsys/registry_results*.csv
# agent-generated briefings/reports — regenerated on demand, not source
qtsys/reports/
# state-migration bundles contain broker keys — never commit
qtsys-state-*.tar.gz

# per-day loss-breaker baseline (runtime state, self-anchored each day)
qtsys/day_baseline.json

# runtime log
server.log

# private build/planning docs — not source-controlled
BUILD-PLAN.md

# new runtime state DBs introduced by the build plan (also matched by *.db)
learning.db
riskgov.db
